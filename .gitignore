# Build trees (out-of-source; deps are fetched fresh by CMake)
/build/
/build-tracy/
build*/

# Python virtualenv (cmake/ninja + pylsl for the test-streams tool)
/.venv/

# Editor / IDE (cmake.sourceDirectory etc. is machine-specific)
/.vscode/

# Dear ImGui persisted window/dock layout (per-machine UI state)
imgui.ini

# Captured screenshots from the UI test suite
/output/

# Recorded data
*.xdf

# Logs
*.log

# OS cruft
.DS_Store
Thumbs.db
